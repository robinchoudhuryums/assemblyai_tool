# AssemblyAI API key (required for audio transcription and analysis)
# Get your key at: https://www.assemblyai.com/dashboard/signup
ASSEMBLYAI_API_KEY=your_api_key_here

# Session secret for cookie signing (REQUIRED in production)
# Generate a strong random string: openssl rand -hex 32
# In development, a random secret is auto-generated if not set (sessions won't persist across restarts)
SESSION_SECRET=your_random_secret_here

# ─── Object Storage (AWS S3) ─────────────────────────────────────────
# Stores audio files, transcripts, and analysis results.
# Without S3_BUCKET configured, falls back to in-memory storage (data lost on restart).
S3_BUCKET=ums-call-archive

# ─── AWS Credentials (for S3 + Bedrock) ──────────────────────────────
# Required for both S3 storage and Bedrock AI analysis.
# Bedrock is HIPAA-eligible under the AWS BAA.
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
# Optional: For IAM role-based authentication
# AWS_SESSION_TOKEN=your_session_token

# ─── AI Model ────────────────────────────────────────────────────────
# Default: us.anthropic.claude-sonnet-4-6 (see server/services/bedrock.ts)
# Available options: see BEDROCK_MODEL_PRESETS in shared/schema.ts
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6

# ─── User Authentication ─────────────────────────────────────────────
# Format: username:password:role:displayName (comma-separated for multiple users)
# Roles: admin, manager, viewer
AUTH_USERS=admin:YourSecurePassword:admin:Admin User

# ─── Data Retention ──────────────────────────────────────────────────
# Auto-purge calls older than N days (default: 90)
# RETENTION_DAYS=90

# ─── Optional Settings ───────────────────────────────────────────────
# PORT=5000
# STORAGE_BACKEND=s3
