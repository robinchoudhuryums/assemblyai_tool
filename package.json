  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=1536' vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && cp server/db/schema.sql dist/schema.sql",
    "start": "NODE_ENV=production node dist/index.js",
    "test": "tsx --test --test-force-exit tests/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=text-summary --include='server/**/*.ts' --exclude='server/**/*.test.ts' tsx --test --test-force-exit tests/*.test.ts",
    "test:client": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "check": "tsc",
    "seed": "tsx seed.ts",
    "seed-admin": "tsx seed-admin.ts",
    "backfill-embeddings": "tsx scripts/backfill-embeddings.ts",
    "eval:rag": "tsx server/scripts/evalRagIntegration.ts"
  },
