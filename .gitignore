# Dependencies
node_modules/

# Environment variables (HIPAA: never commit secrets)
.env
.env.local
.env.production

# Service account keys (HIPAA: never commit credentials)
*.keyfile.json

# Uploaded audio files (HIPAA: may contain PHI)
uploads/

# Build output
dist/

# Coverage reports
coverage/

# Playwright runtime artifacts (test-results/ holds error-context.md +
# screenshots from failed runs; playwright-report/ is the HTML reporter
# output). Both are recreated on every run and CI uploads
# playwright-report/ as a workflow artifact, not via git.
test-results/
playwright-report/

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
